{
  "name": "Adobe Systems Software Ireland Ltd",
  "detect_keywords": [
    "Adobe"
  ],
  "fields": {
    "invoice_number": {
      "regex": "Número\\s+de\\s+factura\\s+(\\S+)",
      "group": 1
    },
    "date": {
      "type": "spanish_dmy",
      "regex": "Fecha\\s+de\\s+la\\s+factura\\s+(\\d{1,2})[/\\-](\\w+)\\.?[/\\-](\\d{4})"
    },
    "vendor_name": {
      "static": "Adobe"
    },
    "excl_vat": {
      "regex": "IMPORTE\\s+NETO\\s+\\(EUR\\)[^\\d]+([\\d.,]+)",
      "group": 1
    },
    "vat_amount": {
      "regex": "TOTAL\\s+\\(EUR\\)[^\\d]+([\\d.,]+)",
      "group": 1
    }
  }
}