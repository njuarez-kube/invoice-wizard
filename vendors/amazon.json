{
  "name": "Amazon ES",
  "detect_keywords": ["amazon", "amazon.es", "amazon services europe"],
  "fields": {
    "invoice_number": {
      "regex": "N[uú]mero\\s+de\\s+la\\s+factura\\s+([A-Z0-9]+)",
      "group": 1
    },
    "date": {
      "type": "spanish_dmy",
      "regex": "Fecha\\s+de\\s+la\\s+factura[^\\n]*?(\\d{1,2})\\s+([a-záéíóúü]+)\\s+(\\d{4})"
    },
    "vendor_name": {
      "static": "Amazon"
    },
    "excl_vat": {
      "type": "vat_table_base"
    },
    "vat_amount": {
      "type": "vat_table_vat"
    }
  }
}
