{
  "name": "Inforconta S.A.",
  "detect_keywords": [
    "Inforconta"
  ],
  "fields": {
    "invoice_number": {
      "regex": "N.\\s*FACTURA\\s+(\\S+)",
      "group": 1
    },
    "date": {
      "type": "spanish_dmy",
      "regex": "FECHA EMISI.N\\s+(\\d{1,2})/(\\w+)\\.?/(\\d{4})"
    },
    "vendor_name": {
      "static": "Inforconta"
    },
    "excl_vat": {
      "regex": "([\\d.,]+)\\s+\\d+[.,]\\d+%",
      "group": 1
    },
    "vat_amount": {
      "regex": "\\d+[.,]\\d+%\\s+([\\d.,]+)",
      "group": 1
    }
  }
}